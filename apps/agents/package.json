{
  "name": "@pass/agents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preplanner": "npm run build -w @pass/shared",
    "planner": "tsx src/cli/planner.ts",
    "prearchitecture-refinement": "npm run build -w @pass/shared",
    "architecture-refinement": "tsx src/cli/architectureRefinement.ts",
    "prerepo-provision": "npm run build -w @pass/shared",
    "repo-provision": "tsx src/cli/repoProvision.ts",
    "predecomposition": "npm run build -w @pass/shared",
    "decomposition": "tsx src/cli/decomposition.ts",
    "predecomposition-iterator": "npm run build -w @pass/shared",
    "decomposition-iterator": "tsx src/cli/decompositionIterator.ts",
    "preimplementation": "npm run build -w @pass/shared",
    "implementation": "tsx src/cli/implementation.ts",
    "prebuild-orchestrator": "npm run build -w @pass/shared",
    "build-orchestrator": "tsx src/cli/buildOrchestrator.ts",
    "preissue-execution": "npm run build -w @pass/shared",
    "issue-execution": "tsx src/cli/issueExecution.ts",
    "prepr-supervisor": "npm run build -w @pass/shared",
    "pr-supervisor": "tsx src/cli/prSupervisor.ts",
    "prebuild": "npm run build -w @pass/shared",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "npm run build -w @pass/shared",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"(lint later)\""
  },
  "dependencies": {
    "@pass/shared": "*",
    "dotenv": "^16.6.1",
    "yaml": "^2.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
